# ===========================================
# AdCraft AI 广告工作台 环境变量配置
# ===========================================

# 基础配置
NODE_ENV=development
PORT=4177
APP_URL=http://127.0.0.1:5173
API_URL=http://127.0.0.1:4177

# 数据库 (PostgreSQL)
DATABASE_URL=postgresql://ad_ai:ad_ai_password@127.0.0.1:5432/ad_ai

# 缓存/队列 (Redis)
REDIS_URL=redis://127.0.0.1:6379

# JWT 密钥（生产环境必须更换为强随机字符串）
JWT_SECRET=replace-with-long-random-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# 积分规则
REGISTER_BONUS_CREDITS=5

# ===== AI 文本 Provider (Claude / 任意 OpenAI 兼容中转) =====
# 通过 sub2api / new-api 等 OpenAI 兼容网关访问大模型（chat/completions 接口）。
# 本机已运行的 new-api 网关地址为 http://127.0.0.1:3001，其 OpenAI 兼容基址为 /v1。
# 请将下方 API Key 替换为你在 new-api 中创建的「令牌 / Token」。
# 模型名（ANTHROPIC_MODEL）需与你在网关里配置的渠道模型名一致，例如 claude-sonnet-4-20250514。
AI_TEXT_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://apic.aksearch.site
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ===== AI 生图 Provider (GPT-image-2 / sub2api) =====
# 同样走 OpenAI 兼容网关的 /v1（images/generations 接口）。
OPENAI_API_KEY=your-newapi-token-here
OPENAI_BASE_URL=https://apic.aksearch.site
OPENAI_IMAGE_API_KEY=your-newapi-token-here
OPENAI_IMAGE_BASE_URL=https://apic.aksearch.site/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_MODE=async

# ===== 预留备用 Provider =====
BANANA2_ENABLED=false
BANANA2_API_KEY=
BANANA2_BASE_URL=
BANANA2_MODEL=

# ===== 文件存储 =====
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=storage/uploads

# MinIO (可选)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET=adcraft-assets

# ===== 前端端口 =====
VITE_API_BASE_URL=http://127.0.0.1:4177/api
