# ===========================================
# AdCraft AI 广告工作台 环境变量配置
# ===========================================

# 基础配置
NODE_ENV=development
PORT=4177
APP_URL=http://127.0.0.1:5173
API_URL=http://127.0.0.1:4177
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 数据库 (PostgreSQL)
DATABASE_URL=postgresql://ad_ai:ad_ai_password@127.0.0.1:5432/ad_ai

# 缓存/队列 (Redis)
REDIS_URL=redis://127.0.0.1:6379

# JWT 密钥（生产环境必须更换为强随机字符串）
JWT_SECRET=replace-with-long-random-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# 积分规则
REGISTER_BONUS_CREDITS=5

# ===== AI 文本 Provider (Claude / 任意 OpenAI 兼容中转) =====
# 通过 sub2api / new-api 等 OpenAI 兼容网关访问大模型（chat/completions 接口）。
# 本机已运行的 new-api 网关地址为 http://127.0.0.1:3001，其 OpenAI 兼容基址为 /v1。
# 请将下方 API Key 替换为你在 new-api 中创建的「令牌 / Token」。
# 模型名（ANTHROPIC_MODEL）需与你在网关里配置的渠道模型名一致，例如 claude-sonnet-4-20250514。
AI_TEXT_PROVIDER=anthropic
ANTHROPIC_API_KEY=your api key
ANTHROPIC_BASE_URL=https://apic.aksearch.site/v1
ANTHROPIC_MODEL=gpt-5.5

# ===== AI 生图 Provider (GPT-image-2 / OpenAI 兼容 · 同步为主) =====
# 走 OpenAI 兼容网关的同步生图接口（对齐参考项目 gpt_image_playground 的可用实现）。
# 主路径：POST {base_url}/images/generations，body 带 response_format=b64_json，图片内联返回 base64。
# base_url 由你自行配置（例如本机 new-api：http://127.0.0.1:3001/v1，或其它 OpenAI 兼容网关）。
# 图片请求严格走 OPENAI_IMAGE_*（与文本通道 ANTHROPIC_* 完全隔离，互不回退）
OPENAI_IMAGE_API_KEY=your api key
OPENAI_IMAGE_BASE_URL=https://apic.aksearch.site/v1   # ← 生图网关 base_url（需包含 /v1）
OPENAI_IMAGE_MODEL=gpt-image-2
# sync：同步为主（推荐，POST /images/generations 内联拿图）；async：异步提交+轮询（需网关支持 background/async）；auto=sync
OPENAI_IMAGE_MODE=async
OPENAI_IMAGE_SUBMIT_TIMEOUT_MS=600000

# ===== 预留备用 Provider =====
BANANA2_ENABLED=false
BANANA2_API_KEY=
BANANA2_BASE_URL=
BANANA2_MODEL=

# ===== 文件存储 =====
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=storage/uploads

# MinIO (可选)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET=adcraft-assets

# ===== 前端端口 =====
VITE_API_BASE_URL=/api
