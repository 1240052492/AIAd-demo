# ===========================================================
# AdCraft AI — 生产环境变量模板（.env.production.example）
# ===========================================================
# 用法：
#   1) 复制为 .env（或部署平台的环境变量），docker-compose 已 `env_file: .env`。
#   2) 下方 JWT_SECRET / JWT_REFRESH_SECRET 是「示例强随机值」——
#      上线前请务必重新生成你自己的，切勿直接沿用本文件里的示例值！
#      生成命令：openssl rand -base64 48
#   3) CORS_ORIGINS 必须改成你的真实前端域名，否则后端会 fail-fast 拒绝启动。
# ===========================================================

# ----- 基础 -----
NODE_ENV=production
PORT=4177
APP_URL=https://app.example.com
API_URL=https://app.example.com

# ----- 数据库 / Redis -----
# docker-compose 内部会用服务名覆盖为 postgres:5432 / redis:6379；
# 非容器部署请填真实连接串。
DATABASE_URL=postgresql://ad_ai:CHANGE_ME_STRONG_PASSWORD@postgres:5432/ad_ai
REDIS_URL=redis://redis:6379
DB_CONNECTION_LIMIT=20

# ----- JWT 鉴权（示例值，上线前请重新生成！）-----
JWT_SECRET=QxWGdL2NHcMd+zdLR/z8Rhj+oCAD6LYe1oo/tBSLBjObUV8I/J2zWetmLkJfaXMZ
JWT_REFRESH_SECRET=6jBxM7GSrEAqcu0yHxBoZGcs4NaH16jBVYZRGc93gE7qwdGgU97aAzlKbm13cGRq
# access 令牌有效期缩短，降低泄露风险（refresh 令牌负责续期）
JWT_EXPIRES_IN=2h

# ----- CORS 白名单（必改为真实前端域名，多个逗号分隔）-----
CORS_ORIGINS=https://app.example.com
# nginx 反代在前，取真实客户端 IP（限流按 IP 生效）
TRUST_PROXY=1

# ----- 积分规则 -----
REGISTER_BONUS_CREDITS=5

# ----- AI 文本 Provider -----
AI_TEXT_PROVIDER=anthropic
ANTHROPIC_API_KEY=CHANGE_ME
ANTHROPIC_BASE_URL=https://your-gateway/v1
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ----- AI 生图 Provider -----
OPENAI_IMAGE_API_KEY=CHANGE_ME
OPENAI_IMAGE_BASE_URL=https://your-gateway/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_MODE=sync
OPENAI_IMAGE_SUBMIT_TIMEOUT_MS=600000

# ----- 文件存储 -----
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=storage/uploads

# ----- OCR Sidecar（docker-compose 内会覆盖为 http://ocr-sidecar:4188）-----
OCR_SERVICE_URL=http://ocr-sidecar:4188
OCR_REQUEST_TIMEOUT_MS=25000
OCR_MAX_INPUT_EDGE=2048
OCR_MIN_CONFIDENCE=0.7
TEXT_RENDER_FONT_FAMILY=Microsoft YaHei, Noto Sans CJK SC, sans-serif
TEXT_RENDER_MAX_INPUT_PIXELS=40000000
