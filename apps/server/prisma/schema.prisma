generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户与权限
// ============================================

model User {
  id           String   @id @default(cuid())
  phone        String?  @unique
  email        String?  @unique
  nickname     String?
  passwordHash String   @map("password_hash")
  status       String   @default("active") // active, disabled, banned
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles        UserRole[]
  creditAccount CreditAccount?
  projects     Project[]
  assets       Asset[]
  generationJobs GenerationJob[]
  creditTransactions CreditTransaction[]
  rechargeOrders RechargeOrder[]

  @@map("users")
}

model Role {
  id        String @id @default(cuid())
  code      String @unique // admin, user, guest
  name      String
  users     UserRole[]

  @@map("roles")
}

model UserRole {
  userId    String
  roleId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ============================================
// 积分账户
// ============================================

model CreditAccount {
  id             String   @id @default(cuid())
  userId         String   @unique
  balance        Int      @default(0)
  frozenBalance  Int      @default(0) @map("frozen_balance")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions   CreditTransaction[]

  @@map("credit_accounts")
}

model CreditTransaction {
  id            String   @id @default(cuid())
  userId        String
  accountId     String
  type          String   // register_bonus, admin_adjust, freeze, consume, refund, recharge
  amount        Int      // 正数=增加 负数=扣除
  balanceAfter  Int      @map("balance_after")
  relatedType   String?  @map("related_type") // project, job, template, manual
  relatedId     String?  @map("related_id")
  reason        String?
  operatorId    String?  @map("operator_id")
  createdAt     DateTime @default(now()) @map("created_at")

  account       CreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 热点路径：GET /api/credits/transactions 为 WHERE userId ORDER BY createdAt DESC 分页，
  // 复合索引可消除排序节点（实测 7.3ms -> 0.06ms）。
  @@index([userId, createdAt(sort: Desc)])
  @@map("credit_transactions")
}

// ============================================
// 项目
// ============================================

model Project {
  id              String   @id @default(cuid())
  userId          String
  title           String
  businessType    String   @map("business_type") // storefront_sign, culture_wall, lightbox, poster, brand_vi, etc.
  status          String   @default("draft") // draft, generating, editing, completed, exported
  briefJson       Json?    @map("brief_json")
  currentVersionId String? @map("current_version_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions        ProjectVersion[]
  assets          Asset[]
  generationJobs  GenerationJob[]

  // 热点路径：GET /api/projects 列表为 WHERE userId ORDER BY updatedAt DESC 分页，
  // 复合索引可消除排序节点（实测 9.8ms -> 0.05ms）。
  @@index([userId, updatedAt(sort: Desc)])
  @@map("projects")
}

model ProjectVersion {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  canvasJson  Json?    @map("canvas_json")
  createdAt   DateTime @default(now()) @map("created_at")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_versions")
}

// ============================================
// 素材和结果
// ============================================

model Asset {
  id            String   @id @default(cuid())
  userId        String?
  projectId     String?
  generationJobId String? @map("generation_job_id")
  type          String   // upload_environment, generated_design, composited_preview, export_png, export_pdf, export_svg
  storageKey    String   @map("storage_key")
  url           String
  mimeType      String?  @map("mime_type")
  width         Int?
  height        Int?
  size          Int?     // bytes
  metadataJson  Json?    @map("metadata_json")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  templates     Template[] @relation("TemplateCover")

  @@index([generationJobId])
  @@map("assets")
}

// ============================================
// 系统设置（键值存储，value 为 JSON 字符串）
// ============================================

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("system_settings")
}

model ForbiddenWord {
  id          String   @id @default(cuid())
  word        String   @unique
  category    String   @default("general")
  matchType   String   @default("contains") @map("match_type") // contains / whole_word
  action      String   @default("block") // block / flag / replace
  replacement String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([enabled])
  @@index([category])
  @@map("forbidden_words")
}

// ============================================
// 会员与充值（新增：解决"充值积分"链路缺失 + 会员套餐可配置）
// 说明：新增表使用标量 userId（不挂 User 反向关系），避免改动 User 模型与关系校验。
// ============================================

model MembershipPlan {
  id           String   @id @default(cuid())
  code         String   @unique // monthly 月度会员 / yearly 年度会员 / enterprise 企业会员 / points 购买积分
  name         String
  description  String?
  price        Int      @default(0) // 价格（单位：分，避免浮点误差）
  points       Int      @default(0) // 赠送/包含积分
  durationDays Int?     @map("duration_days") // 会员时长（天）；points 类型为 null
  rate         Float    @default(1) // 消费倍率（如代理默认 0.7）
  permissions  Json?    @map("permissions") // 权限包，与服务端角色权限合并
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships UserMembership[]

  @@map("membership_plans")
}

model UserMembership {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  planId        String   @map("plan_id")
  plan          MembershipPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  status        String   @default("active") @map("status") // active / expired / canceled
  pointsGranted Int      @default(0) @map("points_granted")
  startedAt     DateTime @default(now()) @map("started_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([planId])
  @@map("user_memberships")
}

model RechargeOrder {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderNo    String   @unique @map("order_no")
  amount     Int      // 充值金额（分）
  points     Int      // 到账积分
  rate       Float    @default(1) // 下单时倍率（代理）
  status     String   @default("pending") @map("status") // pending / paid / failed / canceled
  payChannel String?  @map("pay_channel")
  paidAt     DateTime? @map("paid_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@map("recharge_orders")
}

// 角色权限配置：服务端生效（游客/用户/代理/管理员 的倍率与权限包）
model RoleConfig {
  id          String   @id @default(cuid())
  roleCode    String   @unique @map("role_code") // guest / user / agent / admin
  rate        Float    @default(1) // 消费倍率（代理默认 0.7）
  permissions  Json?    @map("permissions") // { canGenerate, canCompose, canAccessAdmin, ... }
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("role_configs")
}

// ============================================
// 生成任务
// ============================================

model GenerationJob {
  id              String    @id @default(cuid())
  userId          String
  projectId       String?
  provider        String    // anthropic, openai, banana2
  model           String
  jobType         String    @map("job_type") // brief, prompt, image_generation, composition, export
  status          String    @default("queued") // queued, submitted, processing, succeeded, failed, canceled
  prompt          String?
  requestJson     Json?     @map("request_json")
  responseJson    Json?     @map("response_json")
  errorMessage    String?   @map("error_message")
  creditsFrozen   Int       @default(0) @map("credits_frozen")
  creditsConsumed Int       @default(0) @map("credits_consumed")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@map("generation_jobs")
}

// ============================================
// 模板和工作流
// ============================================

model Template {
  id              String   @id @default(cuid())
  title           String
  category        String   // 门头招牌, 文化墙, LOGO, 海报, etc.
  businessType    String   @map("business_type")
  coverAssetId    String?  @map("cover_asset_id")
  prompt          String
  configJson      Json?    @map("config_json")
  sortOrder       Int      @default(0) @map("sort_order")
  isPublic        Boolean  @default(true) @map("is_public")
  createdAt       DateTime @default(now()) @map("created_at")

  coverAsset      Asset?   @relation("TemplateCover", fields: [coverAssetId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([businessType])
  @@map("templates")
}

model WorkflowTemplate {
  id              String   @id @default(cuid())
  title           String
  businessType    String   @map("business_type")
  description     String?
  stepsJson       Json     @map("steps_json") // [{role, name, systemPrompt, requireConfirm, creditCost}]
  creditRuleJson  Json?    @map("credit_rule_json")
  isPublic        Boolean  @default(true) @map("is_public")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("workflow_templates")
}

// ============================================
// Provider 配置
// ============================================

model AiProviderConfig {
  id              String   @id @default(cuid())
  provider        String   // anthropic, openai, openai_image, banana2
  displayName     String   @map("display_name")
  baseUrl         String   @map("base_url")
  model           String
  enabled         Boolean  @default(true)
  priority        Int      @default(0)
  configJson      Json?    @map("config_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("ai_provider_configs")
}
